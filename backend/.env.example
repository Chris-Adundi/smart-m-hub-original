APP_ENV=production
MONGO_URL=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/smart_m_hub
# MONGO_URL_FILE=/run/secrets/mongo_url
DB_NAME=smart_m_hub_beta
SUPER_ADMIN_EMAIL=chrisadundi1@gmail.com
SUPER_ADMIN_PASSWORD=replace-with-a-strong-temporary-password
SECRET_KEY=replace-with-a-long-random-secret
# SECRET_KEY_FILE=/run/secrets/secret_key
ALLOWED_ORIGINS=https://school.example.com,https://admin.example.com
FRONTEND_URL=https://school.example.com
SERVICE_NAME=smart-m-hub-api
SERVICE_VERSION=1.0.0
LOG_FORMAT=json
LOG_LEVEL=INFO
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
PASSWORD_MIN_LENGTH=8
MAX_UPLOAD_MB=5
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=0
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=20000

# External notifications (leave providers disabled until credentials are configured)
EMAIL_PROVIDER=disabled
EMAIL_FROM=notifications@example.com
# For EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
# For EMAIL_PROVIDER=sendgrid
# EMAIL_API_KEY=
# EMAIL_API_URL=https://api.sendgrid.com/v3/mail/send

SMS_PROVIDER=disabled
# For SMS_PROVIDER=africastalking
# SMS_API_KEY=
# SMS_USERNAME=
# SMS_SENDER_ID=
# SMS_API_URL=https://api.africastalking.com/version1/messaging
# For SMS_PROVIDER=generic, set SMS_API_KEY, SMS_API_URL and optionally SMS_SENDER_ID.

STORAGE_BACKEND=local
# STORAGE_BACKEND=s3
# S3_BUCKET=smart-m-hub-uploads
# AWS_REGION=af-south-1
